# Copy to .env and customize for local development
# Never commit .env to git

# ── Application ────────────────────────────────────────────────────────────────
EDGENT_DEBUG=false
EDGENT_LOG_LEVEL=INFO
EDGENT_HOST=0.0.0.0
EDGENT_PORT=8000
EDGENT_WORKERS=1

# ── Model provider ─────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic
EDGENT_MODEL_PROVIDER=ollama
EDGENT_MODEL_NAME=gemma3:4b

# ── Ollama (used when EDGENT_MODEL_PROVIDER=ollama) ───────────────────────────
EDGENT_OLLAMA_BASE_URL=http://localhost:11434

# ── Edge model constraints ─────────────────────────────────────────────────────
EDGENT_MAX_TOKENS=512
EDGENT_MAX_RETRIES=3
EDGENT_TIMEOUT_SECONDS=30.0
EDGENT_MAX_TOOL_CALLS=5

# ── Job execution ──────────────────────────────────────────────────────────────
EDGENT_JOB_QUEUE_SIZE=100
EDGENT_JOB_TTL_SECONDS=3600
