# Copy to .env and customize for local development
# Never commit .env to git

# These entries are written to prefer existing environment values when
# sourced by a shell. Each variable falls back to a sensible default when
# not set: `VAR=${VAR:-default}`. This makes the file usable as a passthru
# reference for container or system environment injection.

# ── Application ────────────────────────────────────────────────────────────────
EDGENT_DEBUG=${EDGENT_DEBUG:-false}
EDGENT_LOG_LEVEL=${EDGENT_LOG_LEVEL:-INFO}
EDGENT_HOST=${EDGENT_HOST:-0.0.0.0}
EDGENT_PORT=${EDGENT_PORT:-8000}
EDGENT_WORKERS=${EDGENT_WORKERS:-1}

# ── Model provider ─────────────────────────────────────────────────────────────
# Supported in this repo: ollama
# openai and anthropic are placeholders and are not wired up yet
EDGENT_MODEL_PROVIDER=${EDGENT_MODEL_PROVIDER:-ollama}
EDGENT_MODEL_NAME=${EDGENT_MODEL_NAME:-gemma4:e2b}

# ── Ollama (used when EDGENT_MODEL_PROVIDER=ollama) ───────────────────────────
EDGENT_OLLAMA_BASE_URL=${EDGENT_OLLAMA_BASE_URL:-http://ollama:11434}

# ── Edge model constraints ─────────────────────────────────────────────────────
EDGENT_MAX_TOKENS=${EDGENT_MAX_TOKENS:-512}
EDGENT_MAX_RETRIES=${EDGENT_MAX_RETRIES:-3}
EDGENT_TIMEOUT_SECONDS=${EDGENT_TIMEOUT_SECONDS:-30.0}
EDGENT_MAX_TOOL_CALLS=${EDGENT_MAX_TOOL_CALLS:-5}

# ── Job execution ──────────────────────────────────────────────────────────────
EDGENT_JOB_QUEUE_SIZE=${EDGENT_JOB_QUEUE_SIZE:-100}
EDGENT_JOB_TTL_SECONDS=${EDGENT_JOB_TTL_SECONDS:-3600}

# -- Developer tokens (replace with your own for local development) --
# Copilot CLI token
# Create a fine-grained PAT at
# [github.com/settings/personal-access-tokens/new](https://github.com/settings/personal-access-tokens/new).
# Under **Permissions → Account permissions** add **Copilot Requests (read)**.
COPILOT_GITHUB_TOKEN=${COPILOT_GITHUB_TOKEN}

# Context7 API key. https://context7.com/dashboard get it here.
CONTEXT7_API_KEY=${CONTEXT7_API_KEY}

# Forward the Copilot API token so that evals/runner.py can reach
# api.githubcopilot.com from inside the container.
GITHUB_COPILOT_API_TOKEN=${GITHUB_COPILOT_API_TOKEN:-}