# Run tests for opencode plugins using Bun and Vitest. This command is intended to be run from the root of the opencode repository.
# --coverage.provider istanbul forces Istanbul on Bun (Bun lacks V8 Profiler API that Vitest v4's default v8 provider requires).
test *ARGS:
  bun run --bun test {{ARGS}} --coverage.provider=istanbul

# Run linter for opencode plugins
lint *ARGS:
  bun run --bun lint {{ARGS}}

# Run typecheck for opencode plugins
# Directory args (ending with /) are stripped because forwarding them as file paths to tsc
# causes it to ignore tsconfig.json, producing TS5112. The include patterns in tsconfig.json
# already cover all files that a directory arg would target. Flags like --skipLibCheck are preserved.
typecheck *ARGS:
  @_filtered=""; for _a in {{ARGS}}; do if [ "${_a%/}" != "$_a" ]; then continue; fi; _filtered="${_filtered} ${_a}"; done; bun run --bun typecheck $_filtered

mutation:
  bun stryker