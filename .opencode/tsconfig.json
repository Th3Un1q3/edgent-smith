{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "vitest/globals"],
    "allowImportingTsExtensions": true,
    "paths": {
      "bun:fs": ["./plugins/tests/__mocks__/bun-fs.ts"],
      "bun": ["./plugins/tests/__mocks__/bun.ts"]
    }
  },
  "include": ["plugins/**/*.ts", "plugins/tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
