{
    "$schema": "https://opencode.ai/config.json",
    "model": "local/qwen3.6-28b-reap20-a3b",
    "provider": {
        "local": {
            "options": {
                "baseURL": "http://host.docker.internal:1289/v1"
            },
            "models": {
                "qwen3.6-28b-reap20-a3b": {
                    "name": "l-qwen3.6-28b",
                    "attachment": true,
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 65536,
                        "output": 2048
                    }
                },
                "google/gemma-4-26b-a4b-qat": {
                    // "qwen/qwen3.6-35b-a3b": {
                    "name": "lmstudio-advanced",
                    "temperature": true,
                    "attachment": true,
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "qwen3.5-9b-mtp": {
                    "name": "lmstudio-default",
                    "temperature": true,
                    "attachment": true,
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "google/gemma-4-e4b": {
                    "name": "lmstudio-fast",
                    "temperature": true,
                    "attachment": true
                },
                "google/gemma-4-e2b": {
                    "name": "lmstudio-ultra-fast",
                    "temperature": true,
                    "attachment": true
                }
            }
        }
    },
    "permission": {
        "list_mcp_resources": "deny",
        "bash": {
            "*": "allow",
            "git *": "ask",
            "rtk git *": "ask",
            "rtk rewrite git *": "ask",
            "git diff *": "allow",
            "git status *": "allow"
        },
        "gateway_*": "deny",
        "gateway_mcp-find": "allow",
        "gateway_code-mode": "allow",
        "gateway_mcp-exec": "allow"
    },
    "plugin": [
        "@mohak34/opencode-notifier@latest",
    ],
    "mcp": {
        "gateway": {
            "type": "remote",
            "url": "http://mcp_gateway:8080/mcp"
        },
    }
}