{
    "$schema": "https://opencode.ai/config.json",
    "model": "local/qwen3.6-28b-reap20-a3b",
    "compaction": {
        "auto": true,
        "prune": false,
        "reserved": 10000
    },
    "instructions": [
        ".opencode/instructions/steering-handling.md"
    ],
    "provider": {
        "local": {
            "options": {
                "baseURL": "http://host.docker.internal:1289/v1"
            },
            "models": {
                "qwen3.6-28b-reap20-a3b": {
                    "name": "l-qwen3.6-28b",
                    "attachment": true,
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 128000,
                        "output": 32768
                    }
                },
                "unsloth/gemma-4-26b-a4b-it-qat": {
                    "name": "l-gemma-4-26b-a4b-ud",
                    "attachment": true,
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 128000,
                        "output": 32768
                    }
                },
                "qwen3.6-14b-a3b-fablevibes": {
                    "name": "l-qwen3.6-14b-a3b-fablevibes",
                    "attachment": true,
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "gemma-4-12b-it-mlx": {
                    "name": "l-gemma-4-12b-it-mlx",
                    "attachment": true,
                    "modalities": {
                        "input": [
                            "text",
                            "image"
                        ],
                        "output": [
                            "text"
                        ]
                    },
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "qwen3.5-9b-mtp": {
                    "name": "l-qwen3.5-9b-mtp",
                    "temperature": true,
                    "attachment": true,
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "google/gemma-4-e4b": {
                    "name": "l-gemma-4-e4b",
                    "temperature": true,
                    "attachment": true
                },
                "google/gemma-4-e2b": {
                    "name": "l-gemma-4-e2b",
                    "temperature": true,
                    "attachment": true
                }
            }
        }
    },
    "permission": {
        "external_directory": {
            "/tmp/*": "allow"
        },
        "webfetch": "deny",
        "list_mcp_resources": "deny",
        "bash": {
            "*": "allow",
            "git *": "ask",
            "rtk git *": "ask",
            "rtk rewrite git *": "ask",
            "rtk git diff *": "allow",
            "rtk git status *": "allow",
            "rtk git show *": "allow",
            "git diff *": "allow",
            "git status *": "allow",
            "git show *": "allow",
            "git log *": "allow",
        },
        "gateway_*": "deny",
        "gateway_mcp-find": "allow",
        "gateway_code-mode": "allow",
        "gateway_mcp-exec": "allow"
    },
    "plugin": [
        "@mohak34/opencode-notifier@latest",
    ],
    "mcp": {
        "gateway": {
            "type": "remote",
            "url": "http://mcp_gateway:8080/mcp"
        },
    }
}