{
    "$schema": "https://opencode.ai/config.json",
    "model": "local/google/gemma-4-26b-a4b-qat",
    "provider": {
        "local": {
            "options": {
                "baseURL": "http://host.docker.internal:1289/v1"
            },
            "models": {
                "google/gemma-4-26b-a4b-qat": {
                    // "qwen/qwen3.6-35b-a3b": {
                    "name": "lmstudio-advanced",
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "qwen3.5-9b-mtp": {
                    "name": "lmstudio-default",
                    "limit": {
                        "context": 256000,
                        "output": 65536
                    }
                },
                "google/gemma-4-e4b": {
                    "name": "lmstudio-fast"
                },
                "google/gemma-4-e2b": {
                    "name": "lmstudio-ultra-fast"
                }
            }
        }
    },
    "instructions": [
        "./.github/instructions/writing-style.instructions.md",
        "./.github/instructions/mcp-tool-usage.instructions.md",
        "./.github/instructions/human-approval.instructions.md"
    ],
    "permission": {
        "bash": {
            "*": "allow",
            "git *": "ask",
            "git diff *": "allow",
            "just approve *": "ask"
        },
        "gateway_*": "deny",
        "gateway_mcp-find": "allow",
        "gateway_code-mode": "allow",
        "gateway_mcp-exec": "allow"
    },
    "plugin": [
        "opencode-ntfy.sh",
        // "opencode-snip@latest",
        // "@tarquinen/opencode-dcp@latest",
        // "@mohak34/opencode-notifier@latest",
        // "@spoons-and-mirrors/subtask2@latest",
        // "oh-my-opencode@latest" // Has ni
    ],
    "mcp": {
        "gateway": {
            "type": "remote",
            "url": "http://mcp_gateway:8080/mcp"
        },
        "codegraph": {
            "type": "local",
            "command": [
                "codegraph",
                "serve",
                "--mcp"
            ],
            "enabled": true
        },
        // "codegraph": {
        //     "type": "local",
        //     "command": [
        //         "codegraph",
        //         "serve",
        //         "--mcp"
        //     ],
        //     "enabled": true
        // },
    }
}